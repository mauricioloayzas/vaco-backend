{
  "name": "personal-finances/backend",
  "description": "Microservices serverless with Bref and DynamoDB to manage the personal finances",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "repositories": [
      {
          "type": "vcs",
          "url": "git@github.com:mauricioloayzas/bob-construye.git"
      }
  ],
  "require": {
    "php": ">=8.4",
    "bref/bref": "^3.0",
    "aws/aws-sdk-php": "^3.200",
    "ramsey/uuid": "^4.9",
    "vlucas/phpdotenv": "^5.6",
    "mauricioloayzas/bob-construye": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\Common\\": "package/Common/src/"
    }
  }
}
